# --- Telegram API Configuration ---
# Get these by logging in to https://my.telegram.org, going to 'API development tools'
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# (Optional) If you want to use a Bot account instead of a personal account, add your Bot Token from @BotFather here.
# NOTE: If using Bot mode, the bot MUST be an admin/member in the target group to see messages.
# If left blank, the script runs in User mode, prompting for your phone number/OTP on first run.
TELEGRAM_BOT_TOKEN=

# (Optional) Phone number and 2FA password for User mode.
# If not specified, they will be prompted on the console.
# Note: You will still need to enter the OTP code manually on first login.
TELEGRAM_PHONE=
TELEGRAM_PASSWORD=

# Name of the session file created in the project folder to keep you logged in.
TELEGRAM_SESSION_NAME=job_sheet_session

# Target Telegram Group(s) / Channel(s) to listen to.
# Can be a username (e.g. my_job_channel), a channel link (e.g. https://t.me/my_job_channel),
# or a negative channel/group ID (e.g. -1001234567890).
# Multiple chats can be specified by separating them with commas.
TELEGRAM_GROUP_IDENTIFIER=https://t.me/addlist/4q2PYC0pH_VjZDk5


# --- Google Sheets Integration Configuration ---
# Integration Method: 'webhook' (Recommended - uses Google Apps Script) or 'api' (uses Google Cloud API and credentials.json)
SHEET_METHOD=webhook

# 1. Configuration for 'webhook' method (Google Apps Script)
# Deploy the provided Apps Script from the README and paste the Web App URL here
GOOGLE_SHEET_WEBHOOK_URL=your_google_apps_script_url_here

# 2. Configuration for 'api' method (Google Cloud Service Account)
# Only required if SHEET_METHOD is set to 'api'
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_SPREADSHEET=Your Spreadsheet Name or ID
GOOGLE_SHEETS_WORKSHEET=Sheet1
